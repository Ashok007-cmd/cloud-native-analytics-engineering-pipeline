# Airflow Environment — copy to .env and fill in ALL values before use
# NEVER commit the filled .env file; it is listed in .gitignore.
#
# Generate Fernet key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Generate a random password:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"

AIRFLOW_UID=50000
AIRFLOW_GID=0

AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__FERNET_KEY=<generate_with_command_above>
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=False
AIRFLOW__CORE__DEFAULT_TIMEZONE=UTC

AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:${AIRFLOW_PG_PASSWORD}@postgres:5432/airflow

# PostgreSQL backend password — use a strong random value, never "airflow"
AIRFLOW_PG_PASSWORD=<change_me>

# Airflow admin UI credentials — default is admin/admin; change before any non-local use
AIRFLOW_ADMIN_PASSWORD=<change_me>

# Optional: Slack webhook for DAG failure alerts
# Create at https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=

# dbt profile/target (used by Cosmos DAG)
DBT_PROFILE=duckdb
DBT_TARGET=dev

# Snowflake credentials (required only for production Snowflake target)
SNOWFLAKE_ACCOUNT=<account>.snowflakecomputing.com
SNOWFLAKE_USER=<your_user>
SNOWFLAKE_PASSWORD=<your_password>
SNOWFLAKE_ROLE=DBT_ROLE
SNOWFLAKE_DATABASE=ONLINE_RETAIL_DB
SNOWFLAKE_WAREHOUSE=ELT_WH
