# Environment files containing secrets (but keep .env.example templates)
.env
.env.*
!.env.example
airflow/.env
airflow/.env.*
!airflow/.env.example

# Airflow runtime files
airflow/logs/
# Auto-generated by Airflow on first run — contains a live fernet_key; never commit
airflow/airflow.cfg
airflow/airflow.db
airflow/simple_auth_manager_passwords.json.generated

# DuckDB databases (all locations)
*.duckdb
*.duckdb.wal
dbt_project/*.duckdb
dbt_project/*.duckdb.wal

# dbt artifacts
dbt_project/target/
dbt_project/dbt_packages/
dbt_project/logs/
dbt_project/.user.yml

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
dbt_venv/
.coverage
.pytest_cache/
.ruff_cache/

# Source data (large CSV files; use scripts/ci_setup.py for CI sample)
data/*.csv

# Log files
logs/
lint.log
*.log

# Backup archives
backups/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# AI tooling working state (session/tool-internal, not project deliverables)
.claude/
.opencode/
.code-review-graph/
.planning/STATE.md
.planning/codebase/
